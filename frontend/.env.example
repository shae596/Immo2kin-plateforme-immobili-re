VITE_APP_NAME="Immo2Kin"
# Laisser vide en dev local : les appels passent par le proxy Vite (CSRF Sanctum OK).
# En prod / preview : URL complète de l'API, ex. https://api.example.com
VITE_API_URL=
VITE_REVERB_APP_KEY=local-reverb-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
# Optionnel : clé publique Stripe (sinon mode test simulé côté API)
VITE_STRIPE_PUBLISHABLE_KEY=
