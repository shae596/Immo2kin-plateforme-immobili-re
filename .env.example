# =============================================================================
# Monorepo — Immo2Kin (Phase 0)
# Copier vers backend/.env, frontend/.env et ai-service/.env selon besoin.
# =============================================================================

# --- Application ---
APP_NAME="Immo2Kin"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- MySQL (Docker: port 3307 si MySQL local occupe 3306) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=immo_platform
DB_USERNAME=immo
DB_PASSWORD=secret

# --- Redis ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Sanctum SPA ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
SESSION_DOMAIN=localhost

# --- Broadcasting / Laravel Reverb ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=immo2kin
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# --- AI microservice ---
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=change-me-in-production

# --- Frontend (Vite) ---
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
